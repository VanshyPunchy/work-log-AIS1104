name: Sync worklog to Notion

on:
  workflow_dispatch:
  schedule:
    - cron: "0 18 * * *"   # every day at 18:00 UTC

concurrency:
  group: sync-worklog
  cancel-in-progress: true

jobs:
  sync:
    runs-on: ubuntu-latest

    steps:
      - name: Check out repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Run sync
        env:
          NOTION_TOKEN: ${{ secrets.NOTION_TOKEN }}
          NOTION_DATA_SOURCE_ID: ${{ secrets.NOTION_DATA_SOURCE_ID }}
          WORKLOG_CSV_URL: ${{ secrets.WORKLOG_CSV_URL }}
        run: python scripts/sync_worklog.py
